{
  "name": "lp-free",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "npx vercel dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "android": "npm run cap:sync && (CAPACITOR_ANDROID_STUDIO_PATH=\"/Applications/Android Studio.app\" npx cap open android || open -a \"Android Studio\" android)",
    "android:run": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.1.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.2.0",
    "@capgo/capacitor-social-login": "^8.3.8",
    "@ionic/react": "^8.8.0",
    "@ionic/react-router": "^8.8.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.0.0",
    "ionicons": "^8.0.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
